<span class="k">def</span> <span class="nf">reduce_markup</span><span class="p">(</span><span class="n">listofMarkup</span><span class="p">,</span> <span class="n">preemptive_list</span><span class="p">):</span>
    <span class="c1"># compute row-, col- or subgrid-wise
